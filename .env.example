# TipJet environment template — copy to .env.local and fill in real values.
# NEXT_PUBLIC_* are exposed to the browser — only publishable/client keys here.

NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_TEST_RECEIVER=0x...

# server-only — creator registry (optional in local dev, REQUIRED in production).
# Vercel's Upstash marketplace integration injects KV_REST_API_URL/KV_REST_API_TOKEN
# instead — the app accepts either pair.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
